{
  "name": "money-rain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "CLOUDFLARE_API_TOKEN=$PAGES_API_TOKEN wrangler pages deploy dist --project-name money-rain-essa --branch=main",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate:local": "wrangler d1 migrations apply money-rain-dev --local",
    "db:seed:local": "wrangler d1 execute money-rain-dev --local --file=./seed/local.sql"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@tanstack/react-query": "5.101.2",
    "clsx": "2.1.1",
    "decimal.js": "10.6.0",
    "jose": "6.2.3",
    "lucide-react": "1.25.0",
    "motion": "12.42.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "react-router-dom": "7.18.1",
    "three": "0.185.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260719.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
